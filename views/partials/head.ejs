<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Kenteken Check</title>
<meta name="description" content="Ontdek de geschiedenis van elk Nederlands voertuig — NAP, APK-status, rijverboden en meer.">
<link rel="preconnect" href="https://fonts.googleapis.com">
<link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet">
<script src="https://kit.fontawesome.com/cb6fe2f1e7.js" crossorigin="anonymous"></script>
<style>
:root {
  --good:        #16a34a;
  --good-bg:     #f0fdf4;
  --good-border: #bbf7d0;
  --warn:        #b45309;
  --warn-bg:     #fffbeb;
  --warn-border: #fde68a;
  --bad:         #dc2626;
  --bad-bg:      #fef2f2;
  --bad-border:  #fecaca;
  --text:        #0f172a;
  --muted:       #64748b;
  --border:      #e2e8f0;
  --bg:          #f1f5f9;
  --surface:     #ffffff;
  --blue:        #2563eb;
  --blue-dark:   #1d4ed8;
  --radius:      10px;
  --shadow:      0 1px 3px rgba(0,0,0,.07);
  --shadow-md:   0 4px 16px rgba(0,0,0,.07);
}

*, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

body {
  font-family: 'Inter', system-ui, sans-serif;
  background: var(--bg);
  color: var(--text);
  font-size: 16px;
  line-height: 1.6;
}

.container {
  max-width: 860px;
  margin: 0 auto;
  padding: 0 24px;
}

/* ── Nav ─────────────────────────────── */
nav {
  background: var(--surface);
  border-bottom: 1px solid var(--border);
}
.nav-inner {
  max-width: 860px;
  margin: 0 auto;
  padding: 0 24px;
  height: 56px;
  display: flex;
  align-items: center;
}
.nav-brand {
  font-weight: 700;
  font-size: 1.05rem;
  color: var(--text);
  text-decoration: none;
}
.nav-brand span { color: var(--blue); }

/* ── Card ────────────────────────────── */
.jumbotron {
  background: var(--surface);
  border: 1px solid var(--border);
  border-radius: var(--radius);
  padding: 32px;
  margin: 28px 0;
  box-shadow: var(--shadow-md);
}

/* ── Form ────────────────────────────── */
form {
  display: flex;
  gap: 8px;
  align-items: center;
  margin: 16px 0;
}
input[type="text"] {
  flex: 1;
  border: 1.5px solid var(--border);
  border-radius: 8px;
  padding: 10px 14px;
  font-size: 1rem;
  font-family: inherit;
  color: var(--text);
  outline: none;
  transition: border-color .15s;
  letter-spacing: .04em;
}
input[type="text"]:focus { border-color: var(--blue); }
input.submit {
  background: var(--blue);
  color: #fff;
  border: none;
  border-radius: 8px;
  padding: 10px 22px;
  font-size: 1rem;
  font-weight: 600;
  font-family: inherit;
  cursor: pointer;
  transition: background .15s;
  white-space: nowrap;
}
input.submit:hover { background: var(--blue-dark); }

/* ── Status headings (standalone h2) ─── */
h2.good, h2.warning, h2.bad {
  font-size: .9rem;
  font-weight: 600;
  padding: 12px 16px;
  border-radius: var(--radius);
  margin: 6px 0;
  display: flex;
  align-items: center;
  gap: 8px;
  border: 1px solid;
  border-left-width: 4px;
}
h2.good    { color: var(--good); background: var(--good-bg); border-color: var(--good-border); border-left-color: var(--good); }
h2.warning { color: var(--warn); background: var(--warn-bg); border-color: var(--warn-border); border-left-color: var(--warn); }
h2.bad     { color: var(--bad);  background: var(--bad-bg);  border-color: var(--bad-border);  border-left-color: var(--bad); }

/* ── Status containers ───────────────── */
.good-container, .bad-container, .warning-container {
  border-radius: var(--radius);
  padding: 16px 20px;
  margin: 8px 0;
  border: 1px solid;
  border-left-width: 4px;
}
.good-container    { background: var(--good-bg); border-color: var(--good-border); border-left-color: var(--good); }
.bad-container     { background: var(--bad-bg);  border-color: var(--bad-border);  border-left-color: var(--bad); }
.warning-container { background: var(--warn-bg); border-color: var(--warn-border); border-left-color: var(--warn); }

/* Strip redundant background/border from h2 when it's inside a container */
.good-container h2.good,
.bad-container h2.bad,
.warning-container h2.warning {
  background: none;
  border: none;
  border-bottom: 1px solid;
  border-radius: 0;
  padding: 0 0 10px;
  margin: 0 0 10px;
}
.good-container    h2.good    { border-color: var(--good-border); }
.bad-container     h2.bad     { border-color: var(--bad-border); }
.warning-container h2.warning { border-color: var(--warn-border); }

/* ── Typography ──────────────────────── */
h1 { font-size: 1.5rem; font-weight: 700; letter-spacing: -.02em; margin-bottom: 8px; }
h2 { font-size: 1rem; }
h3 { font-size: .8rem; font-weight: 600; color: var(--muted); text-transform: uppercase; letter-spacing: .07em; margin: 20px 0 8px; }
p  { color: var(--muted); font-size: .95rem; margin: 6px 0; }
ul, ol { padding-left: 20px; color: var(--muted); font-size: .95rem; }
li { margin-bottom: 4px; }
b  { color: var(--text); }
.fa, .fa-solid { margin-right: 4px; }

/* ── Details / Summary ───────────────── */
details {
  border: 1px solid var(--border);
  border-radius: var(--radius);
  margin: 12px 0;
  overflow: hidden;
  background: var(--surface);
}
summary {
  padding: 12px 16px;
  cursor: pointer;
  user-select: none;
  font-size: .9rem;
  font-weight: 500;
  list-style: none;
  display: flex;
  align-items: center;
  gap: 8px;
}
summary::-webkit-details-marker { display: none; }
summary::before {
  content: '›';
  font-size: 1.2rem;
  line-height: 1;
  color: var(--muted);
  transition: transform .2s;
}
details[open] > summary::before { transform: rotate(90deg); }
details[open] > summary { border-bottom: 1px solid var(--border); }
details > *:not(summary) { padding: 16px; }

/* ── Section divider ─────────────────── */
.section-heading {
  font-size: 1rem;
  font-weight: 600;
  color: var(--text);
  padding: 20px 0 12px;
  border-top: 1px solid var(--border);
  margin-top: 20px;
}

/* ── Hero (index only) ───────────────── */
.hero {
  text-align: center;
  padding: 72px 0 48px;
}
.hero h1 {
  font-size: 2.4rem;
  font-weight: 700;
  letter-spacing: -.03em;
  margin-bottom: 14px;
}
.hero .hero-sub {
  color: var(--muted);
  font-size: 1.05rem;
  max-width: 460px;
  margin: 0 auto 28px;
}
.hero form { max-width: 420px; margin: 0 auto; }

/* ── Page header (results page) ──────── */
.page-header { padding: 28px 0 0; }
.page-header h1 { margin-bottom: 4px; }
.page-header p  { color: var(--muted); font-size: .9rem; margin: 0 0 16px; }

/* ── Footer ──────────────────────────── */
footer {
  border-top: 1px solid var(--border);
  background: var(--surface);
  margin-top: 48px;
}
.footer-content {
  max-width: 860px;
  margin: 0 auto;
  padding: 20px 24px;
  display: flex;
  justify-content: space-between;
  align-items: center;
  font-size: .85rem;
  color: var(--muted);
  flex-wrap: wrap;
  gap: 12px;
}
ul.contact-info { list-style: none; padding: 0; display: flex; gap: 20px; flex-wrap: wrap; }
ul.contact-info li { margin: 0; display: inline; }
.footer-icon { color: var(--blue); margin-right: 4px; }

/* ── Loading overlay ─────────────────── */
#loading-indicator {
  position: fixed;
  inset: 0;
  background: rgba(255,255,255,.8);
  backdrop-filter: blur(4px);
  display: none;
  align-items: center;
  justify-content: center;
  flex-direction: column;
  gap: 16px;
  z-index: 1000;
  font-size: .9rem;
  font-weight: 500;
  color: var(--muted);
}
.spinner {
  width: 36px;
  height: 36px;
  border: 3px solid var(--border);
  border-top-color: var(--blue);
  border-radius: 50%;
  animation: spin .65s linear infinite;
}
@keyframes spin { to { transform: rotate(360deg); } }
</style>
<script>
  function validateInput(event) {
    event.target.value = event.target.value.toUpperCase().replace(/[^A-Z0-9]/g, '');
  }
</script>
